# このファイルは記入例です。実際の値は .env にコピーして使います（.env は Git 管理外）。
# cp .env.example .env

# アプリのリッスンポート（未設定時は 3000）
# PORT="3000"

# データベース接続情報（docker-compose.yml の PostgreSQL に接続）
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/world_beaches?schema=public"

# CORS 許可オリジン（カンマ区切り。未設定時の扱いは実装時に決定）
# CORS_ORIGINS="http://localhost:3000"

# 画像配信元（Cloudflare R2 の配信ドメイン）
# R2_PUBLIC_DOMAIN="https://cdn.example.com"
